#!/usr/bin/env bash
# qtdata-cli — 量潮数据处理流程编排实验
#
# 模拟上层 CLI 串联 qtcloud-data-cli 完成完整的数据处理流程：
#   接收 → 处理 → 交付
#
# 用法:
#   qtdata-cli process <customer-id> <source-url>
#   qtdata-cli demo                     # 运行预设的 mock 演示

set -euo pipefail

QTDATA_CLI="${QTDATA_CLI:-qtcloud-data}"
PROCESSOR="${PROCESSOR:-./bin/processor.py}"
WORKDIR="${WORKDIR:-./work}"

# ── 颜色 ──
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${CYAN}▶${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
fail()  { echo -e "${RED}✗${NC} $1"; exit 1; }

# ── 确保依赖 ──
check_deps() {
    command -v "$QTDATA_CLI" >/dev/null || fail "需要 qtcloud-data CLI，请先安装或设置 QTDATA_CLI"
    command -v python3 >/dev/null || fail "需要 python3"
}

# ── 处理流程 ──
process() {
    local customer_id="$1"
    local source_url="$2"
    local work_dir="${WORKDIR}/${customer_id}"

    mkdir -p "$work_dir"

    echo ""
    echo "══════════════════════════════════════════════"
    echo "  客户: $customer_id"
    echo "  来源: $source_url"
    echo "══════════════════════════════════════════════"
    echo ""

    # ── Step 1: 接收 ──
    info "Step 1/3: 接收客户数据"
    local raw_file="${work_dir}/raw.csv"
    $QTDATA_CLI transfer receive "$source_url" --output "$raw_file"
    ok "已接收: $raw_file"
    echo ""

    # ── Step 2: 处理 ──
    info "Step 2/3: 处理数据"
    local processed_file="${work_dir}/processed.csv"
    if [ -f "$PROCESSOR" ]; then
        python3 "$PROCESSOR" "$raw_file" "$processed_file"
    else
        # 默认：CSV 转义 + 格式规范化（占位处理）
        cp "$raw_file" "$processed_file"
        info "使用默认处理（占位）"
    fi
    ok "已处理: $processed_file"
    echo ""

    # ── Step 3: 交付 ──
    info "Step 3/3: 交付结果"
    local link_file="${work_dir}/share-link.txt"
    $QTDATA_CLI transfer send "$processed_file" --output "$link_file"
    ok "结果已交付"
    echo "  分享链接: $(cat "$link_file")"
    echo ""

    echo "────────────────────────────────────────────"
    ok "客户 $customer_id 流程完成"
    echo "  原始数据: $raw_file"
    echo "  处理结果: $processed_file"
    echo "  交付链接: $(cat "$link_file")"
    echo ""
}

# ── Mock 演示（不依赖真实 CLI） ──
demo() {
    echo ""
    echo "══════════════════════════════════════════════"
    echo "  qtdata-cli 演示 — 完整数据处理流程"
    echo "══════════════════════════════════════════════"
    echo ""

    local demo_dir="${WORKDIR}/demo"
    mkdir -p "$demo_dir"

    # 准备 mock 数据
    echo "col1,col2,col3" > "${demo_dir}/mock_input.csv"
    echo "a,1,10" >> "${demo_dir}/mock_input.csv"
    echo "b,2,20" >> "${demo_dir}/mock_input.csv"
    echo "c,3,30" >> "${demo_dir}/mock_input.csv"

    info "Mock 数据已准备: ${demo_dir}/mock_input.csv"

    # 模拟 receive: 用本地文件代替实际下载
    info "Step 1/3: 模拟接收"
    cp "${demo_dir}/mock_input.csv" "${demo_dir}/raw.csv"
    ok "已接收: ${demo_dir}/raw.csv"
    echo ""

    # 处理
    info "Step 2/3: 处理数据"
    local processed="${demo_dir}/processed.csv"
    if [ -f "$PROCESSOR" ]; then
        python3 "$PROCESSOR" "${demo_dir}/raw.csv" "$processed"
    else
        # 模拟处理：加一行汇总
        cp "${demo_dir}/raw.csv" "$processed"
        echo "total,," >> "$processed"
    fi
    ok "已处理: $processed"
    echo ""

    # 模拟 send: 输出假链接
    info "Step 3/3: 模拟交付"
    echo "https://console.qtcloud.com/delivery/demo-result" > "${demo_dir}/share-link.txt"
    ok "结果已交付"
    echo "  分享链接: https://console.qtcloud.com/delivery/demo-result"
    echo ""

    echo "────────────────────────────────────────────"
    ok "Mock 演示完成"
    echo "  工作目录: ${demo_dir}"
    echo ""

    # 展示工作目录内容
    info "工作目录文件:"
    ls -la "${demo_dir}/"
    echo ""
}

# ── 命令分发 ──
case "${1:-help}" in
    process)
        [ $# -ge 3 ] || fail "用法: qtdata-cli process <customer-id> <source-url>"
        check_deps
        process "$2" "$3"
        ;;
    demo)
        demo
        ;;
    *)
        echo "量潮数据处理编排实验"
        echo ""
        echo "用法:"
        echo "  qtdata-cli process <客户ID> <数据来源URL>    执行完整流程"
        echo "  qtdata-cli demo                             运行 mock 演示"
        echo ""
        echo "环境变量:"
        echo "  QTDATA_CLI=qtcloud-data     CLI 命令路径"
        echo "  PROCESSOR=./bin/processor.py 处理脚本路径"
        echo "  WORKDIR=./work               工作目录"
        ;;
esac
