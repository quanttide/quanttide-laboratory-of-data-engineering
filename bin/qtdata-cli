#!/usr/bin/env bash
# qtdata-cli — 量潮数据处理流程编排
# receive → pipeline → send
#
# 用法:
#   qtdata-cli process <id> <url> [--pipeline <name>|--blueprint <name>]
#   qtdata-cli demo
#   qtdata-cli pipeline list|show <name>
#   qtdata-cli blueprint list|show <name>

set -euo pipefail

QTDATA_CLI="${QTDATA_CLI:-qtcloud-data}"
PIPELINE="${PIPELINE:-csv-standard}"
WORKDIR="${WORKDIR:-/tmp/qtcloud-data}"
PIPELINE_DIR="${PIPELINE_DIR:-.quanttide/data/pipeline}"
BLUEPRINT_DIR="${BLUEPRINT_DIR:-.quanttide/data/blueprint}"

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${CYAN}▶${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
fail()  { echo -e "${RED}✗${NC} $1"; exit 1; }

to_camel() { echo "$1" | sed 's/-\(.\)/\U\1/g'; }

# ── Pipeline 解析 ──
resolve_pipeline() {
  local name="$1"
  [ -f "$name" ] && { echo "$name"; return; }
  [[ "$name" == *,* ]] && { echo "$name"; return; }

  if command -v cue &>/dev/null && [ -d "$PIPELINE_DIR" ]; then
    local key; key=$(to_camel "$name")
    local steps
    steps=$(cue export --out yaml --expression "${key}.steps" "$PIPELINE_DIR" 2>/dev/null \
      | grep 'command:' | sed 's/.*command: //;s/"//g' | tr '\n' ',' | sed 's/,$//')
    [ -n "$steps" ] && { echo "$steps"; return; }
  fi
  fail "找不到 Pipeline: $name"
}

# ── Blueprint 解析：取 blueprint 中引用的 pipeline 名称 ──
resolve_blueprint_pipeline() {
  local name="$1"
  command -v cue &>/dev/null || fail "需要 cue"
  local key; key=$(to_camel "$name")
  local pipe
  pipe=$(cue export --out yaml --expression "${key}.pipeline" "$BLUEPRINT_DIR" 2>/dev/null \
    | sed 's/^"//;s/"$//')
  [ -n "$pipe" ] || fail "Blueprint $name 中未定义 pipeline"
  echo "$pipe"
}

# ── 运行 pipeline 步骤链 ──
run_pipeline() {
  local input="$1" output_dir="$2" pipeline_spec="$3"
  local prev="$input"
  IFS=',' read -ra steps <<< "$pipeline_spec"

  for i in "${!steps[@]}"; do
    local step="${steps[$i]}"
    local step_name; step_name=$(basename "$step" .py)
    local step_output
    if [ $i -eq $((${#steps[@]} - 1)) ]; then
      step_output="${output_dir}/final.csv"
    else
      step_output="${output_dir}/step_${i}_${step_name}.csv"
    fi
    echo >&2 -e "${CYAN}▶${NC}  Step $((i+1))/${#steps[@]}: $step_name"
    if [[ "$step" == *.py ]]; then python3 "$step" "$prev" "$step_output"
    elif [[ "$step" == *.sh ]]; then bash "$step" "$prev" "$step_output"
    else "$step" "$prev" "$step_output"
    fi
    prev="$step_output"
  done
  echo "$prev"
}

# ── 完整流程 ──
process() {
  local customer_id="$1" source_url="$2"
  local pipeline_raw="${PIPELINE}"
  local blueprint_mode=false

  # 解析可选参数
  shift 2
  while [ $# -gt 0 ]; do
    case "$1" in
      --pipeline) pipeline_raw="$2"; shift 2 ;;
      --blueprint)
        pipeline_raw=$(resolve_blueprint_pipeline "$2")
        blueprint_mode=true
        shift 2 ;;
      *) shift ;;
    esac
  done

  local pipeline_spec; pipeline_spec=$(resolve_pipeline "$pipeline_raw")
  local work_dir="${WORKDIR}/${customer_id}"; mkdir -p "$work_dir"

  echo ""
  echo "══════════════════════════════════════════════"
  echo "  客户: $customer_id"
  echo "  来源: $source_url"
  $blueprint_mode && echo "  Blueprint: $pipeline_raw"
  echo "  Pipeline: $pipeline_spec"
  echo "══════════════════════════════════════════════"
  echo ""

  info "Step 1: 接收数据"
  local raw_file="${work_dir}/raw.csv"
  $QTDATA_CLI transfer receive "$source_url" --output "$raw_file"
  ok "已接收"
  echo ""

  info "Step 2: 执行 Pipeline"
  local result_file; result_file=$(run_pipeline "$raw_file" "$work_dir" "$pipeline_spec")
  ok "Pipeline 完成"
  echo ""

  info "Step 3: 交付结果"
  local link_file="${work_dir}/share-link.txt"
  $QTDATA_CLI transfer send "$result_file" --output "$link_file"
  ok "结果已交付: $(cat "$link_file")"
  echo ""
  echo "────────────────────────────────────────────"
  ok "完成: $customer_id"
  echo "  原始数据: $raw_file"
  echo "  最终结果: $result_file"
}

# ── 演示 ──
demo() {
  echo ""; echo "══════════════════════════════════════════════"; echo "  qtdata-cli 演示"; echo "══════════════════════════════════════════════"; echo ""
  local d="${WORKDIR}/demo"; mkdir -p "$d"
  echo "name,amount,note" > "${d}/input.csv"
  echo "alice,100,ok" >> "${d}/input.csv"
  echo "bob,200," >> "${d}/input.csv"
  info "Mock 数据"; echo ""
  info "Step 1: 模拟接收"; cp "${d}/input.csv" "${d}/raw.csv"; ok "已接收"; echo ""
  local pipe_steps; pipe_steps=$(resolve_pipeline "csv-standard")
  info "Step 2: Pipeline（csv-standard）"
  local result; result=$(run_pipeline "${d}/raw.csv" "$d" "$pipe_steps")
  ok "Pipeline 完成"; echo ""
  info "Step 3: 模拟交付"; echo "https://console.qtcloud.com/delivery/demo-result" > "${d}/share-link.txt"; ok "已完成"; echo ""
  echo "────────────────────────────────────────────"; ok "演示完成"; echo ""; echo "最终输出:"; echo ""; cat "${d}/final.csv"; echo ""
}

# ── 通用 list/show ──
list_from_cue() {
  local dir="$1" label="$2"
  command -v cue &>/dev/null || fail "需要 cue"
  echo "可用的 $label:"
  cue export --out yaml "$dir" 2>/dev/null \
    | grep -E '^  name: ' | sed 's/  name: "//;s/"$//' \
    | while read -r n; do echo "  - $n"; done
}

show_from_cue() {
  local dir="$1" name="$2"
  command -v cue &>/dev/null || fail "需要 cue"
  local key; key=$(to_camel "$name")
  cue export --out yaml --expression "$key" "$dir" 2>/dev/null || fail "找不到: $name"
}

# ── 主命令 ──
case "${1:-help}" in
  process)
    [ $# -ge 3 ] || fail "用法: qtdata-cli process <ID> <URL> [--pipeline <n>|--blueprint <n>]"
    process "$2" "$3" "${@:4}"
    ;;
  pipeline)
    case "${2:-help}" in
      list|ls) list_from_cue "$PIPELINE_DIR" "Pipeline" ;;
      show) [ -n "${3:-}" ] && show_from_cue "$PIPELINE_DIR" "$3" || fail "用法: qtdata-cli pipeline show <name>" ;;
      *) echo "用法: qtdata-cli pipeline list|show <name>" ;;
    esac ;;
  blueprint)
    case "${2:-help}" in
      list|ls) list_from_cue "$BLUEPRINT_DIR" "Blueprint" ;;
      show) [ -n "${3:-}" ] && show_from_cue "$BLUEPRINT_DIR" "$3" || fail "用法: qtdata-cli blueprint show <name>" ;;
      *) echo "用法: qtdata-cli blueprint list|show <name>" ;;
    esac ;;
  demo) demo ;;
  *)
    echo "量潮数据流程编排"; echo ""
    echo "用法:"
    echo "  process <ID> <URL> [--pipeline <n>|--blueprint <n>]  完整流程"
    echo "  demo                                                  本地演示"
    echo "  pipeline list|show <name>                             管道管理"
    echo "  blueprint list|show <name>                            蓝图管理"
    echo ""
    echo "环境变量:"
    echo "  QTDATA_CLI=qtcloud-data     CLI 路径"
    echo "  PIPELINE=csv-standard        默认 pipeline"
    echo "  WORKDIR=/tmp/qtcloud-data        临时目录"
    echo "  PIPELINE_DIR=.quanttide/data/pipeline    管道定义"
    echo "  BLUEPRINT_DIR=.quanttide/data/blueprint  蓝图定义"
    ;;
esac
